{
  "name": "tapcam-verifier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:wasm && vite --host 127.0.0.1",
    "build": "npm run build:wasm && tsc --noEmit && vite build",
    "build:wasm": "node scripts/build-wasm.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "npm run test:rust && vitest run",
    "test:rust": "cargo test --manifest-path crates/tapcam-verifier-wasm/Cargo.toml",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/three": "^0.184.1",
    "typescript": "^5.5.4",
    "vite": "^8.0.16",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "libheif-js": "^1.19.8",
    "three": "^0.184.0"
  }
}
